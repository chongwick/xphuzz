try { try { phpcredits(-1073741823); } catch (Exception $e) { } } catch(Error $e) { }
try { try { $vars["SessionHandler"]->read(str_repeat(chr(206), 65537) + str_repeat(chr(129), 65537) + str_repeat(chr(155), 17)); } catch (Exception $e) { } } catch(Error $e) { }
