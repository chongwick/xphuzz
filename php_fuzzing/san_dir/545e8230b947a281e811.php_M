try { try { xml_set_processing_instruction_handler(fopen("/dev/null", "r"), phpinfo); } catch (Exception $e) { } } catch(Error $e) { }
try { try { get_extension_funcs(str_repeat("A", 0x100)); } catch (Exception $e) { } } catch(Error $e) { }
