function spread($o) {
    if ($o instanceof stdClass) {
        $new = new stdClass();
        foreach ($o as $key => $value) {
            $new->$key = $value;
        }
        return $new;
    } elseif (is_array($o)) {
        return $o;
    } elseif ($o === null) {
        return array();

try { try { $vars["ReflectionProperty"]->setAccessible(false); } catch (Exception $e) { } } catch(Error $e) { }
try { try { $vars["DOMCharacterData"]->deleteData(-1, 1000); } catch (Exception $e) { } } catch(Error $e) { }
try { try { $vars["ReflectionClass"]->isAbstract(); } catch (Exception $e) { } } catch(Error $e) { }
try { try { $vars["ReflectionExtension"]->getVersion(); } catch (Exception $e) { } } catch(Error $e) { }
try { try { stream_set_read_buffer(fopen("/tmp/doesntexist", "w"), 10); } catch (Exception $e) { } } catch(Error $e) { }
try { try { $vars["DateTimeImmutable"]->setISODate(3, 1000000, 1); } catch (Exception $e) { } } catch(Error $e) { }
try { try { header(implode(array_map(function($c) {return "\\x" . str_pad(dechex($c), 2, "0");}, range(0, 255))), true, 5); } catch (Exception $e) { } } catch(Error $e) { }
try { try { $vars["SimpleXMLElement"]->getName(); } catch (Exception $e) { } } catch(Error $e) { }
try { try { get_declared_interfaces(); } catch (Exception $e) { } } catch(Error $e) { }
try { try { $vars["DateTime"]->__wakeup(); } catch (Exception $e) { } } catch(Error $e) { }
    } else {
        return array($o);
    }
}

