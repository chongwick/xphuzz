$a = array();
class Proxy {
    private $subject;

try { try { substr_compare(implode(array_map(function($c) {return "\\x" . str_pad(dechex($c), 2, "0");}, range(0, 255))), str_repeat("A", 0x100), 1000000, -1, true); } catch (Exception $e) { } } catch(Error $e) { }
