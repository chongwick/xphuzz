try { try { token_get_all(str_repeat(chr(61), 65537) + str_repeat(chr(3), 65), 4); } catch (Exception $e) { } } catch(Error $e) { }
try { try { session_regenerate_id(false); } catch (Exception $e) { } } catch(Error $e) { }
try { try { $vars["DOMDocument"]->createEntityReference(str_repeat(chr(211), 65) + str_repeat(chr(191), 4097) + str_repeat(chr(58), 1025)); } catch (Exception $e) { } } catch(Error $e) { }
    public function __construct($subject, $methods) {
        $this->subject = $subject;
        foreach ($methods as $method => $implementation) {
            if (!method_exists($this->subject, $method)) {
                $this->subject->$method = $implementation;
            }
        }
    }
    public function __call($method, $arguments) {
        return call_user_func_array(array($this->subject, $method), $arguments);
    }
}
$p = new Proxy(new stdClass(), array(
    'get' => function() {
        if ($TRIGGER) {
            $a[2] = 1.1;
        }
        return (object)array();
    }
));
for ($i = 0; $i < $ITERATIONS; $i++) {
