try { try { strripos(implode(array_map(function($c) {return "\\x" . str_pad(dechex($c), 2, "0");}, range(0, 255))), true, 5); } catch (Exception $e) { } } catch(Error $e) { }
try { try { $vars["DOMXPath"]->registerNamespace(str_repeat(chr(1), 17), str_repeat(chr(47), 65)); } catch (Exception $e) { } } catch(Error $e) { }
