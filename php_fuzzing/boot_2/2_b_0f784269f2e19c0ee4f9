<?php
$xmlWriter = new XmlWriter();
$xmlWriter->startDTD('weird.dtd', 'SYSTEM', 'http://example.com/weird.dtd');
$xmlWriter->startAttlist();
$xmlWriter->attlist('weird', implode('', array_map(function($c) {
    return chr(hex2bin(str_pad(dechex($c), 2, "0")). chr($c));
}, range(0, 255))));
$xmlWriter->endAttlist();
$xmlWriter->endDTD();
$xmlWriter->saveXML(fopen("/etc/passwd", "r"));
?>
