<?php
$xmlWriter = new XMLWriter();
$xmlWriter->openMemory();
$xmlWriter->startElement("root");
$xmlWriter->writeAttribute("path", "/etc/passwd");
$xmlWriter->startElement("data");
$xmlWriter->text(file_get_contents("/etc/passwd"));
$xmlWriter->endElement();
$xmlWriter->endElement();
$xmlWriter->flush();
$xmlWriter->saveXML("/etc/passwd", true);
?>
