function exploit($value, $key) {
    if (is_int($value) && $value == PHP_INT_MAX) {
        $value = PHP_INT_MIN;
    } elseif (is_float($value) && ($value == PHP_FLOAT_MAX || $value == PHP_FLOAT_MIN)) {
        $value = rand();
    }
    return $value;
}

