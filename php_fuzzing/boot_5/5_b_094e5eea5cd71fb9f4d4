<?php
$random_string = "abcdefg". str_repeat("!", 1000);
$encoded_string = base64_encode($random_string). str_repeat("!", 1000);
$hex_string = bin2hex($encoded_string). str_repeat("!", 1000);
$fp = fopen("/tmp/doesntexist", "w");
fwrite($fp, $hex_string);
$fp = gzopen("/tmp/doesntexist", "rb");
$read_len = strlen(gzread($fp, 1000000));
gzclose($fp);
echo $read_len;

?>